# ============================================
# LeadHunterOS - Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Claude AI (Required) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_HAIKU_MODEL=claude-haiku-3-5-20241022
CLAUDE_SONNET_MODEL=claude-sonnet-4-5-20241022

# --- Reddit API (Free at reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=LeadHunterOS/1.0 by YourUsername
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# --- Apify (Twitter/X scraping ~$5-10/mo) ---
APIFY_API_TOKEN=your_apify_token

# --- LinkedIn via OutX ---
OUTX_API_KEY=your_outx_api_key
LINKEDIN_EMAIL=your_linkedin_email

# --- Lead Enrichment ---
# Apollo.io (100 free credits/mo)
APOLLO_API_KEY=your_apollo_api_key
# Hunter.io (25 free searches/mo)
HUNTER_API_KEY=your_hunter_api_key
# People Data Labs ($0.04/record)
PDL_API_KEY=your_pdl_api_key
# Clearbit (free enrichment fallback)
CLEARBIT_API_KEY=your_clearbit_api_key

# --- Bing News API (1K free calls/mo) ---
BING_NEWS_API_KEY=your_bing_news_api_key

# --- Gmail Outreach ---
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# --- PostgreSQL ---
POSTGRES_USER=leadhunter
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=leadhunter_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://leadhunter:changeme_strong_password@postgres:5432/leadhunter_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_random_secret_key_32chars

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678

# --- ICP Configuration ---
ICP_JOB_TITLES=CEO,VP of Sales,Head of Growth,Founder,Sales Director
ICP_INDUSTRIES=SaaS,B2B Software,Technology,FinTech
ICP_COMPANY_SIZE_MIN=10
ICP_COMPANY_SIZE_MAX=500
ICP_SCORE_THRESHOLD_IMMEDIATE=70
ICP_SCORE_THRESHOLD_NURTURE=41

# --- Reddit Subreddits to Monitor ---
REDDIT_SUBREDDITS=sales,entrepreneur,startups,SaaS,smallbusiness,b2b,marketing,leadgeneration

# --- Twitter Keywords to Monitor ---
TWITTER_KEYWORDS=looking for CRM,need outreach tool,switching from Salesforce,B2B lead gen,cold email tool
