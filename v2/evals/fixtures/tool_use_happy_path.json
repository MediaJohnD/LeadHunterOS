    "<tool_call>{\"name\":\"rank_leads\",\"arguments\":{\"leads\":[{\"name\":\"Jane Roe\",\"title\":\"operations manager\",\"company\":\"Acme Services\",\"company_domain\":\"acme-services.com\",\"industry\":\"it services\",\"company_size\":50,\"signals\":[\"hiring surge\",\"expansion\"]}],\"top_n\":3}}</tool_call>",
    "<tool_call>{\"name\":\"orchestrate_playbook\",\"arguments\":{\"objective\":\"test\",\"leads\":[{\"name\":\"Jane Roe\",\"title\":\"operations manager\",\"company\":\"Acme Services\",\"company_domain\":\"acme-services.com\",\"industry\":\"it services\",\"company_size\":50,\"signals\":[\"hiring surge\",\"expansion\"],\"icp_score\":80,\"evidence_score\":70}]}}</tool_call>",
