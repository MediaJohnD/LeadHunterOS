    "<tool_call>{\"name\":\"search_signals\",\"arguments\":{\"query\":\"US SMB\"}</tool_call>",
    "<tool_call>{\"name\":\"search_signals\",\"arguments\":{\"query\":\"US SMB\",\"limit\":2}}</tool_call>",
    "<tool_call>{\"name\":\"rank_leads\",\"arguments\":{\"leads\":[],\"top_n\":2}}</tool_call>",
    "<tool_call>{\"name\":\"orchestrate_playbook\",\"arguments\":{\"objective\":\"test\",\"leads\":[]}}</tool_call>",
