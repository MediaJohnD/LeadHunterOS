# LeadHunterOS v2 - Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ==============================================================
# LOCAL LLM - Lemonade (AMD-first, primary backend)
# Run: lemonade-server serve
# Docs: https://github.com/amd/lemonade
# ==============================================================
LEMONADE_BASE_URL=http://localhost:8000
# Default model - Qwen3 quantized works great on AMD RX 7600 / RX 6600 XT
LEMONADE_MODEL=Qwen/Qwen3-8B-Instruct
# Alternative local models to try:
# LEMONADE_MODEL=Qwen/Qwen3-14B-Instruct
# LEMONADE_MODEL=NousResearch/Hermes-3-Llama-3.1-8B
# LEMONADE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ==============================================================
# CLOUD LLM FALLBACKS (US-based APIs only)
# Used only when Lemonade is unavailable or for heavy tasks
# ==============================================================

# --- Claude Pro / Anthropic (heavy reasoning tasks) ---
# US company - compliant with US-only policy
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-opus-4-5
# Claude Pro account via API - best for complex analysis

# --- ChatGPT Plus / OpenAI (fallback) ---
# US company - compliant with US-only policy
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# --- Perplexity Pro (research/search tasks) ---
# US company - compliant with US-only policy
PERPLEXITY_API_KEY=pplx-your-key-here
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online

# ==============================================================
# DATABASE (PostgreSQL)
# Local: postgresql://postgres:password@localhost:5432/leadhunteros
# Supabase US: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# ==============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadhunteros

# ==============================================================
# US-BASED DATA SOURCE APIs
# ==============================================================

# Apollo.io - US company, B2B contact database
APOLLO_API_KEY=your-apollo-api-key-here

# Hunter.io - US company, email finder
HUNTER_API_KEY=your-hunter-api-key-here

# Clearbit (now HubSpot Enrichment) - US company
CLEARBIT_API_KEY=your-clearbit-api-key-here

# LinkedIn (use carefully - US company)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Crunchbase - US company, funding/company data
CRUNCHBASE_API_KEY=your-crunchbase-api-key-here

# ==============================================================
# AGENT SETTINGS
# ==============================================================
AGENT_MAX_STEPS=15
AGENT_LOG_LEVEL=INFO
# ICP scoring threshold (0-100)
ICP_MIN_SCORE=70
# Prefer local inference (set to false to always use cloud)
PREFER_LOCAL=true
