# LeadHunterOS v2 - Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# =============================================================
# LOCAL LLM (Primary - always tried first)
# =============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=adrienbrault/nous-hermes2pro-llama3-8b:Q4_K_M
# Alternative models to try:
# OLLAMA_MODEL=mistral:7b-instruct
# OLLAMA_MODEL=llama3:8b-instruct

# =============================================================
# CLAUDE FALLBACK (Optional - only used if Ollama unavailable)
# Anthropic is a US company - compliant with US-only policy
# =============================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# =============================================================
# DATABASE (PostgreSQL)
# Local: postgresql://postgres:password@localhost:5432/leadhunteros
# Supabase US: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# =============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadhunteros

# =============================================================
# US-BASED DATA SOURCE APIs
# =============================================================

# Apollo.io - Lead enrichment and prospecting (US company)
APOLLO_API_KEY=your_apollo_api_key_here

# Hunter.io - Email finder (US company)
HUNTER_API_KEY=your_hunter_api_key_here

# NewsAPI.org - News signal monitoring (US company)
NEWSAPI_KEY=your_newsapi_key_here

# Reddit via PRAW - Social signal monitoring (US company)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=LeadHunterOS/2.0 by YourUsername

# =============================================================
# OUTREACH (Optional)
# =============================================================

# SendGrid - Email outreach (US company, Twilio subsidiary)
SENDGRID_API_KEY=SG.your_sendgrid_key_here
FROM_EMAIL=outreach@yourdomain.com

# =============================================================
# AGENT SETTINGS
# =============================================================
AGENT_MAX_ITERATIONS=15
AGENT_LOOP_INTERVAL_MINUTES=60
ICP_SCORE_THRESHOLD=70

# =============================================================
# ICP TARGETING (comma-separated)
# =============================================================
ICP_INDUSTRIES=SaaS,B2B Software,Fintech,HealthTech
ICP_COMPANY_SIZE_MIN=10
ICP_COMPANY_SIZE_MAX=500
ICP_TITLES=VP Sales,Head of Revenue,CRO,Founder,CEO
ICP_KEYWORDS=sales automation,outbound,lead generation,revenue ops
