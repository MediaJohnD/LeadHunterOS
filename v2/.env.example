# LeadHunterOS v2 - Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ==============================================================
# LOCAL LLM - Lemonade (AMD-first, primary backend)
# Run: lemonade serve  (starts on port 13305 by default)
# Docs: https://github.com/lemonade-sdk/lemonade
# Your server info: Version 10.3.0
#
# CRITICAL: Use /api/v1 path (NOT /v1) - Lemonade v10+ requires this
# Correct:   http://localhost:13305/api/v1
# Incorrect: http://localhost:13305/v1  <-- will cause 404 errors
# ==============================================================
LEMONADE_BASE_URL=http://localhost:13305/api/v1
LEMONADE_API_KEY=lemonade

# Model name - must match exactly what 'lemonade status' shows
# Set to 'auto' to auto-detect the currently loaded model
LEMONADE_MODEL=auto

# To load a model manually:
#   lemonade load user.Qwen3-7B-Instruct-Q4_K_M-GGUF
#   lemonade load user.Qwen3-14B-GGUF
# Check what's loaded: lemonade status

# Alternative models to try (uncomment one):
# LEMONADE_MODEL=user.Qwen3-7B-Instruct-Q4_K_M-GGUF
# LEMONADE_MODEL=user.Qwen3-14B-GGUF
# LEMONADE_MODEL=Qwen/Qwen3-8B-Instruct
# LEMONADE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ==============================================================
# CLOUD LLM FALLBACKS (US-based APIs only)
# Used only when Lemonade is unavailable or for heavy tasks
# ==============================================================

# --- Claude Pro / Anthropic (heavy reasoning tasks) ---
# US company - compliant with US-only policy
ANTHROPIC_API_KEY=
# Current model IDs (May 2026): claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-7

# --- ChatGPT Plus / OpenAI (fallback) ---
# US company - compliant with US-only policy
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Perplexity Pro (research / web-search tasks) ---
# US company - compliant with US-only policy
# Current valid model: sonar (NOT llama-3.1-sonar-large-128k-online)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# ==============================================================
# AGENT SETTINGS
# ==============================================================
DEFAULT_LLM_BACKEND=local
ENABLE_CLOUD_FALLBACKS=false
LOCAL_LLM_TIMEOUT_SECONDS=300
AGENT_LOOP_INTERVAL_MINUTES=60
AGENT_MAX_ITERATIONS=15
TEMPERATURE=0.7
MAX_TOKENS=4096
MIN_EVIDENCE_SCORE=45
MIN_SIGNAL_COUNT=1
WEIGHT_ATTRACTION_PCT=40
WEIGHT_ZERO_DEFECT_PCT=35
WEIGHT_EVIDENCE_PCT=25
WEIGHT_ICP_FIT_PCT=35
WEIGHT_INTENT_STRENGTH_PCT=35
WEIGHT_RECENCY_PCT=15
WEIGHT_EVIDENCE_CONFIDENCE_PCT=15
ICP_MIN_COMPANY_SIZE=5
ICP_MAX_COMPANY_SIZE=250
ICP_TARGET_TITLES=owner,founder,president,ceo,coo,operations manager,general manager,sales manager,customer success manager
ICP_TARGET_INDUSTRIES=home services,legal,accounting,it services,logistics,healthcare support,agency,agencies,saas,software

# ==============================================================
# LEAD SEARCH SETTINGS
# ==============================================================
LEAD_SEARCH_QUERY=Atlanta SMB companies in Georgia with hiring, expansion, or funding signals
LEAD_MAX_RESULTS=50
LEAD_OUTPUT_FORMAT=json
ICP_MIN_SCORE=70
TARGET_METRO=Atlanta, GA
TARGET_REGION=Georgia
TARGET_COUNTRY=United States

# ==============================================================
# DATABASE (optional - SQLite default, PostgreSQL for production)
# ==============================================================
DATABASE_URL=sqlite:///./leadhunter.db
# DATABASE_URL=postgresql://user:password@localhost:5432/leadhunter

# ==============================================================
# OPTIONAL PAID API KEYS
# All zero-signup tools work without these.
# Add keys to unlock Apollo, Hunter, and NewsAPI fallback tools.
# ==============================================================
APOLLO_API_KEY=
HUNTER_API_KEY=
NEWSAPI_KEY=
